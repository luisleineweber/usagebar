{
  "schemaVersion": 1,
  "id": "kimi",
  "name": "Kimi Code (Moonshot)",
  "version": "0.0.1",
  "entry": "plugin.js",
  "icon": "icon.svg",
  "brandColor": "#000000",
  "platformSupport": {
    "windows": {
      "state": "experimental",
      "message": "Experimental on Windows. Moonshot/Kimi Code subscription usage from local CLI OAuth. Run `kimi login` so ~/.kimi/credentials/kimi-code.json exists before launching UsageBar."
    }
  },
  "lines": [
    { "type": "progress", "label": "Session", "scope": "overview", "primaryOrder": 1 },
    { "type": "progress", "label": "Weekly", "scope": "overview", "primaryOrder": 2 },
    { "type": "progress", "label": "API Balance", "scope": "overview", "primaryOrder": 3 },
    { "type": "text", "label": "Voucher balance", "scope": "detail" },
    { "type": "text", "label": "Cash balance", "scope": "detail" }
  ]
}

{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "UsageBar",
  "version": "0.1.0-alpha.1",
  "identifier": "com.sunstory.usagebar",
  "build": {
    "beforeDevCommand": "bun run bundle:plugins && bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run bundle:plugins && bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "UsageBar",
        "width": 400,
        "height": 500,
        "resizable": false,
        "decorations": false,
        "transparent": false,
        "shadow": false,
        "visible": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' customprotocol: asset:",
        "connect-src": "'self' ipc: http://ipc.localhost https:",
        "img-src": "'self' asset: http://asset.localhost blob: data:",
        "style-src": "'self' 'unsafe-inline'",
        "font-src": "'self' data:"
      }
    },
    "macOSPrivateApi": false
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "dmg": {
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        },
        "windowSize": {
          "width": 660,
          "height": 400
        }
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/bundled_plugins/**/*",
      "icons/tray-icon.png",
      "icons/icon.png"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVGMzA0N0Q1MzEyNDBCQ0IKUldUTEN5UXgxVWN3WDRrbkg1UW5kRFpHVXdMK25zWm5LRGlSZlR4UWdRMGFmODZab0hMYjFlLzkK",
      "endpoints": [
        "https://github.com/Loues000/usagebar/releases/latest/download/latest.json"
      ]
    }
  }
}
